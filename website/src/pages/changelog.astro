---
import BaseLayout from '../layouts/BaseLayout.astro'

const entries = [
  {
    version: '0.1.0',
    date: '2026-06-29',
    items: [
      'Boss 直聘 L1 半自动投递、人工接管与投递看板',
      '求职偏好、岗位抓取与智能筛选',
      '简历上传解析与在线编辑',
      'Windows / macOS 安装包与自动更新',
      '产品官网 v1'
    ]
  }
]
---

<BaseLayout title="更新日志">
  <main class="mx-auto max-w-3xl px-6 py-12">
    <h1 class="text-3xl font-bold text-white">更新日志</h1>
    <div class="mt-8 space-y-8">
      {entries.map((entry) => (
        <section class="rounded-2xl border border-slate-800 bg-slate-900/40 p-6">
          <div class="flex flex-wrap items-baseline gap-3">
            <h2 class="text-xl font-semibold text-emerald-300">v{entry.version}</h2>
            <time class="text-sm text-slate-500">{entry.date}</time>
          </div>
          <ul class="mt-4 list-disc space-y-2 pl-5 text-slate-400">
            {entry.items.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </section>
      ))}
    </div>
  </main>
</BaseLayout>
