---
import BaseLayout from '../layouts/BaseLayout.astro'
import { readFileSync } from 'node:fs'
import { dirname, join } from 'node:path'
import { fileURLToPath } from 'node:url'

const content = readFileSync(
  join(dirname(fileURLToPath(import.meta.url)), '../content/privacy-policy.md'),
  'utf8'
)
---

<BaseLayout title="隐私政策">
  <main class="mx-auto max-w-3xl px-6 py-12">
    <article class="legal-content prose prose-invert max-w-none">
      <div set:html={content
        .replace(/^# (.+)$/m, '<h1>$1</h1>')
        .replace(/^## (.+)$/gm, '<h2>$1</h2>')
        .replace(/^### (.+)$/gm, '<h3>$1</h3>')
        .replace(/^> (.+)$/gm, '<blockquote><p>$1</p></blockquote>')
        .replace(/^- (.+)$/gm, '<li>$1</li>')
        .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
        .replace(/\n---\n/g, '<hr />')
        .replace(/\n\n/g, '</p><p>')
        .replace(/^(?!<[hbl])/gm, '<p>')
        .replace(/<p><h/g, '<h')
        .replace(/<\/h([1-3])><\/p>/g, '</h$1>')} />
    </article>
  </main>
</BaseLayout>

<style>
  .legal-content :global(h1) {
    @apply mb-6 text-3xl font-bold text-white;
  }
  .legal-content :global(h2) {
    @apply mb-4 mt-8 text-xl font-semibold text-emerald-300;
  }
  .legal-content :global(h3) {
    @apply mb-2 mt-6 text-lg font-medium text-slate-200;
  }
  .legal-content :global(p),
  .legal-content :global(li) {
    @apply text-slate-400 leading-relaxed;
  }
  .legal-content :global(blockquote) {
    @apply my-4 border-l-4 border-emerald-500/40 pl-4 text-slate-500;
  }
  .legal-content :global(hr) {
    @apply my-8 border-slate-800;
  }
</style>
