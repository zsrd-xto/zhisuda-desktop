---
interface Props {
  title: string
  description?: string
}

const { title, description = '智能筛选岗位，确认即投，求职更高效' } = Astro.props
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} — 职速达</title>
    <link rel="icon" type="image/png" href="/favicon.png" />
  </head>
  <body class="min-h-screen bg-slate-950 text-slate-100 antialiased">
    <header class="border-b border-slate-800 bg-slate-900/80 backdrop-blur">
      <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
        <a href="/" class="text-lg font-semibold text-white">职速达</a>
        <nav class="flex gap-4 text-sm text-slate-400">
          <a href="/#download" class="hover:text-emerald-300">下载</a>
          <a href="/changelog" class="hover:text-emerald-300">更新日志</a>
        </nav>
      </div>
    </header>
    <slot />
    <footer class="border-t border-slate-800 bg-slate-900/60">
      <div class="mx-auto flex max-w-6xl flex-wrap items-center justify-between gap-4 px-6 py-8 text-sm text-slate-500">
        <div class="flex flex-wrap gap-4">
          <a href="/terms" class="hover:text-slate-300">用户协议</a>
          <a href="/privacy" class="hover:text-slate-300">隐私政策</a>
          <a href="/changelog" class="hover:text-slate-300">更新日志</a>
        </div>
        <p>© 2026 职速达 · 独立产品，与 OpenClaw 无隶属关系</p>
      </div>
    </footer>
  </body>
</html>
